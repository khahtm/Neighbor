# --- Robinhood Chain RPC ---
# Chain env selector: "testnet" (default) | "mainnet"
CHAIN_ENV=testnet
# Client-readable copy (browser bundle) — keep in sync with CHAIN_ENV.
NEXT_PUBLIC_CHAIN_ENV=testnet

# Alchemy RPC keys (recommended). Leave blank to fall back to public rate-limited RPC.
ALCHEMY_API_KEY=

# Optional explicit RPC overrides (else derived from CHAIN_ENV + ALCHEMY_API_KEY / public)
RPC_URL_TESTNET=
RPC_URL_MAINNET=

# --- Database (Prisma / Postgres) ---
DATABASE_URL=postgresql://user:password@localhost:5432/bankroute?schema=public

# --- Wallet provider (Phase 2) ---
# From dashboard.privy.io. Public (client) app id + server secret.
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# --- LLM (Phase 3): local self-hosted OpenAI-compatible endpoint. Money-path only. ---
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=
LLM_API_KEY=not-needed-for-local

# --- Execution finality (Phase 4) ---
# Confirmations before a soft-confirmed tx is treated as final. Conservative placeholder — measure
# against real RH sequencer reorg behaviour before mainnet.
FINALITY_DEPTH_BLOCKS=12

# --- Compliance / ops (Phase 6) ---
# Global execution kill-switch: 1|true|on|paused pauses ALL execute (reads stay up). Blank = live.
EXECUTION_KILL_SWITCH=
# Local geo override (ISO alpha-2) to exercise the geo-gate without an edge/CDN in front. Prod uses
# x-vercel-ip-country / cf-ipcountry headers. IP geo is a DETERRENT, not a compliance control.
GEO_COUNTRY_OVERRIDE=
