{
  "name": "neighbor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Neighbor — non-custodial AI natural-language swap terminal on Robinhood Chain (swap-only MVP).",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "prisma generate && node scripts/vercel-migrate.mjs && next build",
    "start": "next start --port 3000",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "chain:smoke": "tsx scripts/chain-smoke.ts",
    "check:guards": "tsx scripts/check-intent-guards.ts",
    "check:exec": "tsx scripts/check-execution-guards.ts",
    "check:compliance": "tsx scripts/check-compliance.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@privy-io/react-auth": "^2.0.0",
    "@prisma/client": "^6.2.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "viem": "^2.21.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "prisma": "^6.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
